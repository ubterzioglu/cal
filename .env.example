VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_CLARITY_ID=your-clarity-id

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ALLOWED_ORIGINS=https://community.example.com,https://www.community.example.com
IP_HASH_SALT=replace-with-a-random-secret

# Zoho Mail SMTP - used by /api/feedback to notify the admin of new
# feature suggestions / feedback. Optional: if unset, submissions are still
# saved to Supabase but no email is sent.
ZOHO_SMTP_HOST=smtp.zoho.eu
ZOHO_SMTP_PORT=465
ZOHO_SMTP_USER=your-zoho-address@yourdomain.com
ZOHO_SMTP_PASS=your-zoho-app-specific-password
ADMIN_NOTIFY_EMAIL=ubterzioglu@gmail.com
